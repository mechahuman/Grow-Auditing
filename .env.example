# Copy this file to .env.local and fill in real values.
# See docs/09-environment-and-secrets.md for how to obtain each value.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === YouTube Data API ===
YOUTUBE_API_KEY=

# === Google Sheets ===
GOOGLE_SHEET_ID=
# Base64-encoded service account JSON. On any OS with Python:
# python -c "import base64; print(base64.b64encode(open('service-account.json','rb').read()).decode())"
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# === AI Provider ===
# Set to 'groq' (free tier) or 'anthropic' (production)
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# === App config ===
# Used for auth redirects (session handling after login)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# === Cron ===
# Secret token Vercel sends with cron requests — generate any random string
CRON_SECRET=

# === Optional ===
SENTRY_DSN=

# === Autonomous Lead Scouting ===
AUTONOMOUS_QUERIES_PER_RUN=
AUTONOMOUS_RESULTS_PER_QUERY=
AUTONOMOUS_MIN_SUBSCRIBERS=
AUTONOMOUS_MAX_SUBSCRIBERS=
AUTONOMOUS_GROQ_MODEL=
AUTONOMOUS_RUN_SECRET=
NEXT_PUBLIC_AUTONOMOUS_RUN_SECRET=

# === Resend Email ===
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_RECIPIENTS=
